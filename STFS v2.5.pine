//@version=5
// =====================================================================
// STFS v2 — Contextual Strategy Selector
// =====================================================================
// Single unified indicator: trend + context + strategy selector + tweak engine.
// Manual inputs: IV Rank (slider), Event flag (dropdown). Everything else live.
//
// Recommends WHAT and APPROXIMATELY WHERE. Validate strikes + credit/debit
// on TWS/IBKR option chain before order entry.
// =====================================================================

indicator("STFS v2.5 — Contextual Selector", overlay=true, max_labels_count=500)

// =====================================================================
// 1. INPUTS
// =====================================================================

grp_trend = "Trend & Momentum (legacy core)"
emaFastLen   = input.int(8,  "EMA Fast", minval=1, group=grp_trend)
emaMidLen    = input.int(21, "EMA Mid",  minval=1, group=grp_trend)
emaSlowLen   = input.int(34, "EMA Slow", minval=1, group=grp_trend)
hmaLen       = input.int(15, "HMA Length", minval=1, group=grp_trend)
rsiLen       = input.int(14, "RSI Length", minval=1, group=grp_trend)
adxDiLen     = input.int(14, "DI Length",  minval=1, group=grp_trend)
adxSmoothLen = input.int(14, "ADX Smoothing", minval=1, group=grp_trend)
obvMaLen     = input.int(21, "OBV EMA Length", minval=1, group=grp_trend)
adxThreshold = input.float(20.0, "ADX Trend Threshold", step=0.5, group=grp_trend)

grp_ctx = "Context thresholds"
drift_strong_up = input.float(3.0,  "Drift STRONG_UP threshold (%, 10d)", step=0.1, group=grp_ctx)
drift_mild_up   = input.float(1.0,  "Drift MILD_UP threshold (%, 10d)",   step=0.1, group=grp_ctx)
vol_expand      = input.float(1.3,  "Vol EXPANDING ratio (ATR10/ATR60)",  step=0.05, group=grp_ctx)
vol_compress    = input.float(0.8,  "Vol COMPRESSED ratio",               step=0.05, group=grp_ctx)
term_backward   = input.float(1.0,  "Term BACKWARDATION (VIX/VIX3M)",     step=0.01, group=grp_ctx)
term_contango   = input.float(0.95, "Term CONTANGO (VIX/VIX3M)",          step=0.01, group=grp_ctx)
skew_crash      = input.float(140,  "Skew CRASH_FEAR threshold",          step=1, group=grp_ctx)
skew_complacent = input.float(120,  "Skew COMPLACENT threshold",          step=1, group=grp_ctx)
credit_stress   = input.float(-1.0, "Credit STRESSED (HYG %, 5d)",        step=0.1, group=grp_ctx)
adx_strong      = input.float(25.0, "ADX STRONG_TREND threshold",         step=0.5, group=grp_ctx)

grp_manual = "Manual inputs (update weekly)"
iv_rank = input.int(45, "IV Rank (0-100, check TWS)", minval=0, maxval=100, group=grp_manual, tooltip="SPX IV Rank. 0=cheapest 52w, 100=most expensive. Check on TWS weekly.")
event_flag = input.string("None", "Event this week", options=["None", "Tier-1 (FOMC/CPI/NFP)", "Tier-2 (PPI/PCE/Retail)", "OPEX", "Multiple"], group=grp_manual, tooltip="Check TradingView economic calendar Monday morning.")

grp_positions = "Currently open positions (update when entering/exiting)"
pos_a14  = input.bool(false, "A14 open",          group=grp_positions)
pos_fly  = input.bool(false, "Flyagonal open",    group=grp_positions)
pos_te   = input.bool(false, "TimeEdge open",     group=grp_positions)
pos_tz   = input.bool(false, "TimeZone open",     group=grp_positions)
pos_dir  = input.bool(false, "Directional open",  group=grp_positions)

grp_data = "Data sources"
sym_vix   = input.symbol("CBOE:VIX",   "VIX",    group=grp_data)
sym_vix3m = input.symbol("CBOE:VIX3M", "VIX3M",  group=grp_data)
sym_vix9d = input.symbol("CBOE:VIX9D", "VIX9D",  group=grp_data)
sym_skew  = input.symbol("CBOE:SKEW",  "SKEW",   group=grp_data)
sym_hyg   = input.symbol("AMEX:HYG",   "HYG",    group=grp_data)
sym_dxy   = input.symbol("TVC:DXY",    "DXY",    group=grp_data)

grp_disp = "Display"
showDashboard = input.bool(true, "Show Dashboard", group=grp_disp)
showSignals   = input.bool(true, "Show LONG/SHORT markers", group=grp_disp)
dashboardPos  = input.string("Top Right", "Dashboard Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=grp_disp)

// =====================================================================
// 2. LEGACY STFS CORE
// =====================================================================

emaFast = ta.ema(close, emaFastLen)
emaMid  = ta.ema(close, emaMidLen)
emaSlow = ta.ema(close, emaSlowLen)
hma     = ta.hma(close, hmaLen)

rsi = ta.rsi(close, rsiLen)
[plusDI, minusDI, adx] = ta.dmi(adxDiLen, adxSmoothLen)

obvStep = close > close[1] ? volume : close < close[1] ? -volume : 0.0
obv = ta.cum(obvStep)
obvEma = ta.ema(obv, obvMaLen)

bullTrend = emaFast > emaMid and emaMid > emaSlow
bearTrend = emaFast < emaMid and emaMid < emaSlow
hmaUp     = hma > hma[1]
hmaDown   = hma < hma[1]
priceAboveMid = close > emaMid
priceBelowMid = close < emaMid
adxStrongNow = adx > adxThreshold
rsiBull = rsi > 50
rsiBear = rsi < 50
obvBull = obv > obvEma
obvBear = obv < obvEma
diBull = plusDI > minusDI
diBear = minusDI > plusDI

longScore = (bullTrend ? 1 : 0) + (hmaUp ? 1 : 0) + (adxStrongNow ? 1 : 0) + (rsiBull ? 1 : 0) + (obvBull ? 1 : 0) + (diBull ? 1 : 0) + (priceAboveMid ? 1 : 0)
shortScore = (bearTrend ? 1 : 0) + (hmaDown ? 1 : 0) + (adxStrongNow ? 1 : 0) + (rsiBear ? 1 : 0) + (obvBear ? 1 : 0) + (diBear ? 1 : 0) + (priceBelowMid ? 1 : 0)

strongLong  = longScore >= 6 and bullTrend and hmaUp and adxStrongNow
strongShort = shortScore >= 6 and bearTrend and hmaDown and adxStrongNow

// =====================================================================
// 3. EXTERNAL DATA FEEDS
// =====================================================================

f_daily(sym) => request.security(sym, "D", close, lookahead=barmerge.lookahead_off)
f_daily_prev(sym, n) => request.security(sym, "D", close[n], lookahead=barmerge.lookahead_off)

vix_now    = f_daily(sym_vix)
vix_prev1  = f_daily_prev(sym_vix, 1)
vix3m_now  = f_daily(sym_vix3m)
vix9d_now  = f_daily(sym_vix9d)
skew_now   = f_daily(sym_skew)
hyg_now    = f_daily(sym_hyg)
hyg_5d_ago = f_daily_prev(sym_hyg, 5)
dxy_now    = f_daily(sym_dxy)

data_vix_ok   = not na(vix_now)   and vix_now > 0
data_vix3m_ok = not na(vix3m_now) and vix3m_now > 0
data_skew_ok  = not na(skew_now)  and skew_now > 0
data_hyg_ok   = not na(hyg_now)   and not na(hyg_5d_ago) and hyg_5d_ago != 0
data_dxy_ok   = not na(dxy_now)   and dxy_now > 0

// --- Data staleness tracking (Phase 2.5) ---
// Bars since each feed last had valid data. Zero = fresh, N = N bars stale.
var int vix_stale_bars   = 0
var int vix3m_stale_bars = 0
var int skew_stale_bars  = 0
var int hyg_stale_bars   = 0
var int dxy_stale_bars   = 0

vix_stale_bars   := data_vix_ok   ? 0 : vix_stale_bars + 1
vix3m_stale_bars := data_vix3m_ok ? 0 : vix3m_stale_bars + 1
skew_stale_bars  := data_skew_ok  ? 0 : skew_stale_bars + 1
hyg_stale_bars   := data_hyg_ok   ? 0 : hyg_stale_bars + 1
dxy_stale_bars   := data_dxy_ok   ? 0 : dxy_stale_bars + 1

// Any feed stale by 2+ bars? (worth flagging on dashboard)
any_data_stale = vix_stale_bars >= 2 or vix3m_stale_bars >= 2 or skew_stale_bars >= 2 or hyg_stale_bars >= 2 or dxy_stale_bars >= 2

// =====================================================================
// 4. DERIVED SIGNALS
// =====================================================================

ret_10d = (close - close[10]) / close[10] * 100
drift_state = ret_10d > drift_strong_up ? "STRONG_UP" : ret_10d > drift_mild_up ? "MILD_UP" : ret_10d < -drift_strong_up ? "STRONG_DN" : ret_10d < -drift_mild_up ? "MILD_DN" : "FLAT"

atr10 = ta.atr(10)
atr60 = ta.atr(60)
atr_pct10 = atr10 / close * 100
atr_pct60 = atr60 / close * 100
vol_ratio = atr_pct60 > 0 ? atr_pct10 / atr_pct60 : 1.0
vol_state = vol_ratio > vol_expand ? "EXPANDING" : vol_ratio < vol_compress ? "COMPRESSED" : "NORMAL"

term_ratio = data_vix_ok and data_vix3m_ok and vix3m_now > 0 ? vix_now / vix3m_now : na
term_state = na(term_ratio) ? "UNKNOWN" : term_ratio > term_backward ? "BACKWARDATION" : term_ratio < term_contango ? "CONTANGO" : "FLAT"

event_shock_ratio = data_vix_ok and vix_now > 0 and not na(vix9d_now) ? vix9d_now / vix_now : na
event_shock_state = na(event_shock_ratio) ? "UNKNOWN" : event_shock_ratio > 1.05 ? "EVENT_PRICED_IN" : event_shock_ratio < 0.95 ? "COMPLACENT" : "NORMAL"

skew_state = not data_skew_ok ? "UNKNOWN" : skew_now > skew_crash ? "CRASH_FEAR" : skew_now < skew_complacent ? "COMPLACENT" : "NORMAL"

hyg_ret_5d = data_hyg_ok ? (hyg_now - hyg_5d_ago) / hyg_5d_ago * 100 : na
credit_state = na(hyg_ret_5d) ? "UNKNOWN" : hyg_ret_5d < credit_stress ? "STRESSED" : hyg_ret_5d > 1.0 ? "BID" : "NEUTRAL"

trend_strength_state = adx > adx_strong ? "STRONG_TREND" : adx > 20 ? "MILD_TREND" : "CHOP"

ret_10d_mean = ta.sma(ret_10d, 60)
ret_10d_std  = ta.stdev(ret_10d, 60)
ret_z = ret_10d_std > 0 ? (ret_10d - ret_10d_mean) / ret_10d_std : 0.0
stretch_state = (rsi > 70 or ret_z > 2) ? "OVERBOUGHT" : (rsi < 30 or ret_z < -2) ? "OVERSOLD" : "NEUTRAL"

// =====================================================================
// 5. CONTEXT STATE
// =====================================================================

bool is_crisis = (credit_state == "STRESSED") and ((data_vix_ok and vix_now > 28) or skew_state == "CRASH_FEAR")
bool is_risk_off = (credit_state == "STRESSED") or (data_vix_ok and vix_now > 25) or (term_state == "BACKWARDATION")
bool is_mean_rev_dn = (stretch_state == "OVERSOLD") and (credit_state != "STRESSED") and (data_vix_ok and vix_now < 25)
bool is_mean_rev_up = (stretch_state == "OVERBOUGHT") and (drift_state == "MILD_UP" or drift_state == "STRONG_UP")
bool is_drift_up_trending = (drift_state == "STRONG_UP") and (trend_strength_state == "STRONG_TREND") and (vol_state == "NORMAL")
bool is_drift_up_calm = (drift_state == "MILD_UP" or drift_state == "STRONG_UP") and (vol_state != "EXPANDING") and (term_state == "CONTANGO")
bool is_chop_low_vol = (trend_strength_state == "CHOP") and (vol_state == "COMPRESSED") and (data_vix_ok and vix_now < 18)
bool is_chop_normal = (trend_strength_state == "CHOP") and (vol_state == "NORMAL")

ctx_state = is_crisis ? "CRISIS" : is_risk_off ? "RISK_OFF_VOL" : is_mean_rev_dn ? "MEAN_REV_DN" : is_mean_rev_up ? "MEAN_REV_UP" : is_drift_up_trending ? "DRIFT_UP_TRENDING" : is_drift_up_calm ? "DRIFT_UP_CALM" : is_chop_low_vol ? "CHOP_LOW_VOL" : "CHOP_NORMAL_VOL"

// --- Context state persistence counter (Phase 2.5) ---
// Counts bars since ctx_state last changed. Uses `var` to persist across bars.
var int ctx_persist_bars = 0
ctx_persist_bars := ctx_state == ctx_state[1] ? ctx_persist_bars + 1 : 1

// =====================================================================
// 6. MACRO REGIME
// =====================================================================

dxy_prev1 = f_daily_prev(sym_dxy, 1)
dxy_chg = data_dxy_ok and not na(dxy_prev1) and dxy_prev1 > 0 ? (dxy_now - dxy_prev1) / dxy_prev1 * 100 : na
hyg_prev1 = f_daily_prev(sym_hyg, 1)
hyg_chg_1d = data_hyg_ok and not na(hyg_prev1) and hyg_prev1 > 0 ? (hyg_now - hyg_prev1) / hyg_prev1 * 100 : na
vix_chg_1d = data_vix_ok and not na(vix_prev1) and vix_prev1 > 0 ? (vix_now - vix_prev1) / vix_prev1 * 100 : na

bool mr_risk_off   = (not na(hyg_chg_1d) and hyg_chg_1d < -0.5) or (not na(vix_chg_1d) and vix_chg_1d > 5.0)
bool mr_liquidity  = (not na(dxy_chg) and dxy_chg < -0.3)
bool mr_goldilocks = (not na(vix_chg_1d) and vix_chg_1d < 0) and (data_hyg_ok and not na(hyg_chg_1d) and hyg_chg_1d > -0.1)

macro_regime = mr_risk_off ? "RISK OFF" : mr_liquidity ? "LIQUIDITY" : mr_goldilocks ? "GOLDILOCKS" : "NEUTRAL"

// --- Macro regime persistence counter (Phase 2.5) ---
var int regime_persist_bars = 0
regime_persist_bars := macro_regime == macro_regime[1] ? regime_persist_bars + 1 : 1

// =====================================================================
// 7. STRATEGY SCORING
// =====================================================================

f_ctx_pts_a14(s) => s == "CRISIS" ? 30 : s == "RISK_OFF_VOL" ? 40 : s == "MEAN_REV_DN" ? 35 : s == "MEAN_REV_UP" ? 10 : s == "DRIFT_UP_TRENDING" ? 5 : s == "DRIFT_UP_CALM" ? 5 : s == "CHOP_LOW_VOL" ? 10 : 15
f_ctx_pts_fly(s) => s == "DRIFT_UP_CALM" ? 40 : s == "DRIFT_UP_TRENDING" ? 30 : s == "CHOP_NORMAL_VOL" ? 25 : s == "MEAN_REV_DN" ? 20 : s == "CHOP_LOW_VOL" ? 15 : s == "MEAN_REV_UP" ? 10 : s == "RISK_OFF_VOL" ? 5 : s == "CRISIS" ? 0 : 10
f_ctx_pts_te(s) => s == "CHOP_LOW_VOL" ? 40 : s == "CHOP_NORMAL_VOL" ? 30 : s == "DRIFT_UP_CALM" ? 20 : s == "MEAN_REV_UP" ? 10 : s == "MEAN_REV_DN" ? 10 : s == "DRIFT_UP_TRENDING" ? 5 : s == "RISK_OFF_VOL" ? 0 : s == "CRISIS" ? 0 : 10
f_ctx_pts_tz(s) => s == "CHOP_NORMAL_VOL" ? 40 : s == "CHOP_LOW_VOL" ? 30 : s == "DRIFT_UP_CALM" ? 25 : s == "MEAN_REV_DN" ? 15 : s == "MEAN_REV_UP" ? 10 : s == "DRIFT_UP_TRENDING" ? 5 : s == "RISK_OFF_VOL" ? 5 : s == "CRISIS" ? 0 : 10
f_ctx_pts_dir(s) => s == "DRIFT_UP_TRENDING" ? 40 : s == "DRIFT_UP_CALM" ? 25 : s == "MEAN_REV_DN" ? 20 : s == "CHOP_NORMAL_VOL" ? 10 : s == "CHOP_LOW_VOL" ? 5 : s == "MEAN_REV_UP" ? 5 : s == "RISK_OFF_VOL" ? 0 : s == "CRISIS" ? 0 : 5

vix_level = data_vix_ok ? vix_now : 18.0

vol_pts_a14 = vix_level > 22 ? 20 : vix_level > 18 ? 12 : 5
vol_pts_fly = vix_level >= 14 and vix_level <= 20 ? 20 : vix_level > 20 and vix_level <= 25 ? 10 : 5
vol_pts_te  = vix_level < 18 ? 20 : vix_level < 22 ? 10 : 0
vol_pts_te_term = term_state == "CONTANGO" ? 5 : 0
vol_pts_te_total = vol_pts_te + vol_pts_te_term
vol_pts_tz  = vix_level >= 18 and vix_level <= 25 ? 20 : 8
vol_pts_dir = vix_level < 20 ? 15 : vix_level < 25 ? 8 : 0

trend_pts_a14 = 10
trend_pts_fly = trend_strength_state == "MILD_TREND" ? 15 : trend_strength_state == "CHOP" ? 10 : 5
trend_pts_te  = trend_strength_state == "CHOP" ? 15 : trend_strength_state == "MILD_TREND" ? 5 : 0
trend_pts_tz  = trend_strength_state == "CHOP" ? 15 : trend_strength_state == "MILD_TREND" ? 8 : 3
trend_pts_dir = trend_strength_state == "STRONG_TREND" ? 15 : trend_strength_state == "MILD_TREND" ? 8 : 0

iv_pts_a14 = iv_rank > 60 ? 15 : iv_rank > 40 ? 10 : 3
iv_pts_fly = iv_rank >= 30 and iv_rank <= 60 ? 15 : iv_rank < 30 ? 10 : 5
iv_pts_te  = iv_rank < 40 ? 15 : iv_rank < 60 ? 8 : 0
iv_pts_tz  = iv_rank >= 40 and iv_rank <= 70 ? 15 : 5
iv_pts_dir = iv_rank < 40 ? 15 : iv_rank < 60 ? 8 : 0

stretch_pts_a14 = stretch_state == "OVERSOLD" ? 10 : 0
stretch_pts_fly = stretch_state == "NEUTRAL" ? 5 : 0
stretch_pts_te  = stretch_state == "NEUTRAL" ? 5 : 0
stretch_pts_tz  = stretch_state == "NEUTRAL" ? 5 : 0
stretch_pts_dir = stretch_state == "OVERSOLD" ? 10 : stretch_state == "NEUTRAL" ? 3 : 0

// --- Position-correlation penalty (Phase 2.5) ---
// Same strategy already open: -15 (heavy discourage of stacking)
// Correlated strategy open: -8
// Correlation map: A14<->Flyagonal (both BWB, gap risk), TimeEdge<->TimeZone (both calendars)
// Penalty capped at -20 per strategy so nothing gets zeroed out.

pen_a14_same = pos_a14 ? -15 : 0
pen_a14_corr = pos_fly ? -8  : 0
pen_a14 = math.max(pen_a14_same + pen_a14_corr, -20)

pen_fly_same = pos_fly ? -15 : 0
pen_fly_corr = pos_a14 ? -8  : 0
pen_fly = math.max(pen_fly_same + pen_fly_corr, -20)

pen_te_same = pos_te ? -15 : 0
pen_te_corr = pos_tz ? -8  : 0
pen_te = math.max(pen_te_same + pen_te_corr, -20)

pen_tz_same = pos_tz ? -15 : 0
pen_tz_corr = pos_te ? -8  : 0
pen_tz = math.max(pen_tz_same + pen_tz_corr, -20)

pen_dir = pos_dir ? -15 : 0  // Directional is correlation-free

score_a14 = math.max(f_ctx_pts_a14(ctx_state) + vol_pts_a14 + trend_pts_a14 + iv_pts_a14 + stretch_pts_a14 + pen_a14, 0)
score_fly = math.max(f_ctx_pts_fly(ctx_state) + vol_pts_fly + trend_pts_fly + iv_pts_fly + stretch_pts_fly + pen_fly, 0)
score_te  = math.max(f_ctx_pts_te(ctx_state)  + vol_pts_te_total + trend_pts_te + iv_pts_te + stretch_pts_te + pen_te, 0)
score_tz  = math.max(f_ctx_pts_tz(ctx_state)  + vol_pts_tz + trend_pts_tz + iv_pts_tz + stretch_pts_tz + pen_tz, 0)
score_dir = math.max(f_ctx_pts_dir(ctx_state) + vol_pts_dir + trend_pts_dir + iv_pts_dir + stretch_pts_dir + pen_dir, 0)

// Any positions open? (for dashboard flag)
any_position_open = pos_a14 or pos_fly or pos_te or pos_tz or pos_dir
position_count = (pos_a14 ? 1 : 0) + (pos_fly ? 1 : 0) + (pos_te ? 1 : 0) + (pos_tz ? 1 : 0) + (pos_dir ? 1 : 0)

max_score = math.max(score_a14, math.max(score_fly, math.max(score_te, math.max(score_tz, score_dir))))

winner = max_score == score_a14 ? "A14" : max_score == score_fly ? "FLYAGONAL" : max_score == score_te ? "TIMEEDGE" : max_score == score_tz ? "TIMEZONE" : "DIR_DIAGONAL"

f_second_score() =>
    s1 = winner == "A14"          ? -1.0 : float(score_a14)
    s2 = winner == "FLYAGONAL"    ? -1.0 : float(score_fly)
    s3 = winner == "TIMEEDGE"     ? -1.0 : float(score_te)
    s4 = winner == "TIMEZONE"     ? -1.0 : float(score_tz)
    s5 = winner == "DIR_DIAGONAL" ? -1.0 : float(score_dir)
    math.max(s1, math.max(s2, math.max(s3, math.max(s4, s5))))

second_score = f_second_score()

runner_up = second_score == float(score_a14) and winner != "A14" ? "A14" : second_score == float(score_fly) and winner != "FLYAGONAL" ? "FLYAGONAL" : second_score == float(score_te) and winner != "TIMEEDGE" ? "TIMEEDGE" : second_score == float(score_tz) and winner != "TIMEZONE" ? "TIMEZONE" : "DIR_DIAGONAL"

conviction = max_score

// =====================================================================
// 8. TWEAK ENGINE
// =====================================================================

size_mult = conviction >= 85 ? 1.15 : conviction >= 70 ? 1.0 : conviction >= 50 ? 0.65 : 0.25
floor_trade_mode = conviction < 50

event_is_tier1 = event_flag == "Tier-1 (FOMC/CPI/NFP)" or event_flag == "Multiple"
event_any = event_flag != "None"
size_mult_final = event_is_tier1 ? math.min(size_mult, 0.5) : size_mult

dte_base_a14 = 14
dte_base_fly = 9
dte_base_te  = 15
dte_base_tz  = 15
dte_base_dir = 17

dte_shift_raw = vol_state == "EXPANDING" ? -0.25 : vol_state == "COMPRESSED" ? 0.20 : 0.0
dte_shift_event = event_is_tier1 ? math.min(dte_shift_raw, -0.20) : dte_shift_raw
dte_shift_pct = math.max(math.min(dte_shift_event, 0.40), -0.40)

f_tweaked_dte(base) => math.round(base * (1 + dte_shift_pct))

dte_tweaked = winner == "A14" ? f_tweaked_dte(dte_base_a14) : winner == "FLYAGONAL" ? f_tweaked_dte(dte_base_fly) : winner == "TIMEEDGE" ? f_tweaked_dte(dte_base_te) : winner == "TIMEZONE" ? f_tweaked_dte(dte_base_tz) : f_tweaked_dte(dte_base_dir)

delta_base_a14 = 35
delta_base_fly = 30
delta_base_te  = 50
delta_base_tz  = 14
delta_base_dir = 30

delta_shift_raw = vol_state == "EXPANDING" ? 5 : vol_state == "COMPRESSED" ? -5 : 0
delta_shift_drift_up = (drift_state == "STRONG_UP" and (winner == "A14" or winner == "TIMEZONE")) ? delta_shift_raw - 3 : delta_shift_raw
delta_shift_drift_dn = (drift_state == "STRONG_DN" and winner == "FLYAGONAL") ? delta_shift_drift_up - 3 : delta_shift_drift_up
delta_shift = math.max(math.min(delta_shift_drift_dn, 10), -10)

delta_tweaked = winner == "A14" ? delta_base_a14 + delta_shift : winner == "FLYAGONAL" ? delta_base_fly + delta_shift : winner == "TIMEEDGE" ? delta_base_te + delta_shift : winner == "TIMEZONE" ? delta_base_tz + delta_shift : delta_base_dir + delta_shift

width_shift_raw = vol_state == "EXPANDING" ? -0.20 : vol_state == "COMPRESSED" ? 0.15 : 0.0
width_shift_pct = math.max(math.min(width_shift_raw, 0.50), -0.50)

a14_upper_w = math.round(40 * (1 + width_shift_pct))
a14_lower_w = math.round(20 * (1 + width_shift_pct))
fly_lower_to_short = math.round(40 * (1 + width_shift_pct))
fly_short_to_upper = math.round(10 * (1 + width_shift_pct))

struct_mod = event_is_tier1 ? "Drop front shorts - Tier-1 event this week" : (winner == "TIMEEDGE" and term_state == "BACKWARDATION") ? "SKIP - calendar hates backwardation" : (winner == "FLYAGONAL" and skew_state == "CRASH_FEAR") ? "Put VERTICAL instead of diagonal (skew rich)" : ((winner == "TIMEEDGE" or winner == "TIMEZONE") and iv_rank < 30) ? "VERTICAL instead of calendar (IV too low)" : (iv_rank > 70 and winner == "DIR_DIAGONAL") ? "Consider credit spread instead (IV rich)" : "Standard"

// =====================================================================
// 9. FLOOR TRADE SPEC
// =====================================================================

floor_dte = 8
floor_short_delta = 18
floor_wing = 10
floor_size_mult = 0.25

// =====================================================================
// 10. ACTION TEXT
// =====================================================================

f_winner_display(w) => w == "A14" ? "A14 (Put BWB)" : w == "FLYAGONAL" ? "Flyagonal" : w == "TIMEEDGE" ? "TimeEdge (SPX Dbl Cal)" : w == "TIMEZONE" ? "TimeZone (RUT)" : "Directional Diagonal"

// Effective display name — reflects actual structure after tweak engine
// so Winner cell and Plan cell never contradict each other
f_effective_display(w, mod) =>
    if mod == "VERTICAL instead of calendar (IV too low)"
        w == "TIMEEDGE" ? "TimeEdge -> Vertical (low IV)" : "TimeZone -> Vertical (low IV)"
    else if mod == "Put VERTICAL instead of diagonal (skew rich)"
        "Flyagonal -> Vertagonal (skew)"
    else if mod == "SKIP - calendar hates backwardation"
        "TimeEdge -> SKIP (backwardation)"
    else if mod == "Drop front shorts - Tier-1 event this week"
        f_winner_display(w) + " [event-safe]"
    else if mod == "Consider credit spread instead (IV rich)"
        "Dir Diagonal -> Credit Spread (high IV)"
    else
        f_winner_display(w)

action_header = floor_trade_mode ? "FLOOR TRADE" : f_effective_display(winner, struct_mod)

tweaked_plan_normal = "DTE " + str.tostring(dte_tweaked) + " | Short " + str.tostring(delta_tweaked) + "D | Size " + str.tostring(size_mult_final, "#.##") + "x" + (struct_mod != "Standard" ? " | " + struct_mod : "")
tweaked_plan_floor = "Put Credit Spread | DTE ~" + str.tostring(floor_dte) + " | Short " + str.tostring(floor_short_delta) + "D | 10pt wing | Size 0.25x"
tweaked_plan = floor_trade_mode ? tweaked_plan_floor : tweaked_plan_normal

// --- Position display string (Phase 2.5) ---
pos_display = not any_position_open ? "None" : (pos_a14 ? "A14 " : "") + (pos_fly ? "Fly " : "") + (pos_te ? "TE " : "") + (pos_tz ? "TZ " : "") + (pos_dir ? "Dir " : "")

// --- Staleness display string (Phase 2.5) ---
// Only shows concerning staleness; otherwise "All fresh"
stale_vix_txt   = vix_stale_bars   >= 2 ? "VIX "   + str.tostring(vix_stale_bars)   + "b " : ""
stale_vix3m_txt = vix3m_stale_bars >= 2 ? "VIX3M " + str.tostring(vix3m_stale_bars) + "b " : ""
stale_skew_txt  = skew_stale_bars  >= 2 ? "SKEW "  + str.tostring(skew_stale_bars)  + "b " : ""
stale_hyg_txt   = hyg_stale_bars   >= 2 ? "HYG "   + str.tostring(hyg_stale_bars)   + "b " : ""
stale_dxy_txt   = dxy_stale_bars   >= 2 ? "DXY "   + str.tostring(dxy_stale_bars)   + "b " : ""
stale_display = any_data_stale ? stale_vix_txt + stale_vix3m_txt + stale_skew_txt + stale_hyg_txt + stale_dxy_txt : "All fresh"

// =====================================================================
// 11. PLOTS
// =====================================================================

plot(emaFast, title="EMA 8",  color=color.new(color.green, 0), linewidth=2)
plot(emaMid,  title="EMA 21", color=color.new(color.blue, 0), linewidth=2)
plot(emaSlow, title="EMA 34", color=color.new(color.red, 0), linewidth=2)
plot(hma,     title="HMA",    color=hmaUp ? color.new(color.teal, 0) : color.new(color.fuchsia, 0), linewidth=3)

pFast = plot(emaFast, display=display.none)
pSlow = plot(emaSlow, display=display.none)
fill(pFast, pSlow, color=bullTrend ? color.new(color.green, 85) : bearTrend ? color.new(color.red, 85) : color.new(color.gray, 88))

longSignal  = strongLong  and not strongLong[1]
shortSignal = strongShort and not strongShort[1]

plotshape(showSignals and longSignal, title="Long Signal", text="LONG", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 0), textcolor=color.black, size=size.small)
plotshape(showSignals and shortSignal, title="Short Signal", text="SHORT", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

alertcondition(longSignal,  title="STFS Strong Long",  message="STFS v2: STRONG LONG setup")
alertcondition(shortSignal, title="STFS Strong Short", message="STFS v2: STRONG SHORT setup")

// =====================================================================
// 12. DASHBOARD
// =====================================================================

tablePosition = dashboardPos == "Top Right" ? position.top_right : dashboardPos == "Top Left" ? position.top_left : dashboardPos == "Bottom Right" ? position.bottom_right : position.bottom_left

var table dash = table.new(tablePosition, 2, 28, border_width=1)

f_state_color(_condBull, _condBear) => _condBull ? color.new(color.green, 0) : _condBear ? color.new(color.red, 0) : color.new(color.gray, 15)

f_drift_color(s) => s == "STRONG_UP" ? color.new(color.lime, 0) : s == "MILD_UP" ? color.new(color.green, 20) : s == "STRONG_DN" ? color.new(color.red, 0) : s == "MILD_DN" ? color.new(color.red, 30) : color.new(color.gray, 30)

f_vol_color(s) => s == "EXPANDING" ? color.new(color.orange, 0) : s == "COMPRESSED" ? color.new(color.blue, 30) : color.new(color.gray, 30)

f_ctx_color(s) => s == "CRISIS" ? color.new(color.maroon, 0) : s == "RISK_OFF_VOL" ? color.new(color.red, 0) : s == "MEAN_REV_DN" ? color.new(color.orange, 20) : s == "MEAN_REV_UP" ? color.new(color.orange, 40) : s == "DRIFT_UP_TRENDING" ? color.new(color.lime, 0) : s == "DRIFT_UP_CALM" ? color.new(color.green, 20) : s == "CHOP_LOW_VOL" ? color.new(color.blue, 40) : color.new(color.gray, 20)

f_conviction_color(c) => c >= 85 ? color.new(color.lime, 0) : c >= 70 ? color.new(color.green, 10) : c >= 50 ? color.new(color.orange, 20) : color.new(color.red, 10)

f_term_color(s) => s == "BACKWARDATION" ? color.new(color.red, 10) : s == "CONTANGO" ? color.new(color.green, 30) : color.new(color.gray, 30)

f_skew_color(s) => s == "CRASH_FEAR" ? color.new(color.red, 10) : s == "COMPLACENT" ? color.new(color.orange, 30) : color.new(color.gray, 30)

f_credit_color(s) => s == "STRESSED" ? color.new(color.red, 0) : s == "BID" ? color.new(color.green, 20) : color.new(color.gray, 30)

f_stretch_color(s) => s == "OVERBOUGHT" ? color.new(color.orange, 0) : s == "OVERSOLD" ? color.new(color.aqua, 20) : color.new(color.gray, 30)

f_macro_color(r) => r == "RISK OFF" ? color.new(color.red, 10) : r == "LIQUIDITY" ? color.new(color.purple, 30) : r == "GOLDILOCKS" ? color.new(color.green, 20) : color.new(color.gray, 30)

f_event_color(is_t1, any_e) => is_t1 ? color.new(color.red, 20) : any_e ? color.new(color.orange, 40) : color.new(color.gray, 50)

if barstate.islast and showDashboard
    table.cell(dash, 0, 0, "STFS v2.5 - SELECTOR", text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.normal)
    table.cell(dash, 1, 0, str.tostring(ret_10d, "#.##") + "% / 10d", text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.small)

    table.cell(dash, 0, 1, "Trend", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 1, bullTrend ? "Bullish" : bearTrend ? "Bearish" : "Neutral", text_color=color.white, bgcolor=f_state_color(bullTrend, bearTrend), text_size=size.small)

    table.cell(dash, 0, 2, "L/S score", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 2, "L " + str.tostring(longScore) + " / S " + str.tostring(shortScore), text_color=color.white, bgcolor=color.new(color.blue, 65), text_size=size.small)

    table.cell(dash, 0, 3, "Drift", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 3, drift_state + " (" + str.tostring(ret_10d, "#.#") + "%)", text_color=color.white, bgcolor=f_drift_color(drift_state), text_size=size.small)

    table.cell(dash, 0, 4, "Realized vol", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 4, vol_state + " (" + str.tostring(vol_ratio, "#.##") + ")", text_color=color.white, bgcolor=f_vol_color(vol_state), text_size=size.small)

    table.cell(dash, 0, 5, "Term structure", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 5, term_state + (na(term_ratio) ? "" : " (" + str.tostring(term_ratio, "#.##") + ")"), text_color=color.white, bgcolor=f_term_color(term_state), text_size=size.small)

    table.cell(dash, 0, 6, "Skew", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 6, skew_state + (data_skew_ok ? " (" + str.tostring(skew_now, "#") + ")" : ""), text_color=color.white, bgcolor=f_skew_color(skew_state), text_size=size.small)

    table.cell(dash, 0, 7, "Credit", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 7, credit_state + (na(hyg_ret_5d) ? "" : " (" + str.tostring(hyg_ret_5d, "#.##") + "%)"), text_color=color.white, bgcolor=f_credit_color(credit_state), text_size=size.small)

    table.cell(dash, 0, 8, "Stretch", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 8, stretch_state + " (RSI " + str.tostring(rsi, "#") + ")", text_color=color.white, bgcolor=f_stretch_color(stretch_state), text_size=size.small)

    table.cell(dash, 0, 9, "CTX STATE", text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.small)
    table.cell(dash, 1, 9, ctx_state + " (bar " + str.tostring(ctx_persist_bars) + ")", text_color=color.white, bgcolor=f_ctx_color(ctx_state), text_size=size.small)

    table.cell(dash, 0, 10, "Macro regime", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 10, macro_regime + " (bar " + str.tostring(regime_persist_bars) + ")", text_color=color.white, bgcolor=f_macro_color(macro_regime), text_size=size.small)

    table.cell(dash, 0, 11, "IV Rank (manual)", text_color=color.white, bgcolor=color.new(color.black, 50), text_size=size.small)
    table.cell(dash, 1, 11, str.tostring(iv_rank), text_color=color.white, bgcolor=color.new(color.black, 50), text_size=size.small)

    table.cell(dash, 0, 12, "Event flag", text_color=color.white, bgcolor=color.new(color.black, 50), text_size=size.small)
    table.cell(dash, 1, 12, event_flag, text_color=color.white, bgcolor=f_event_color(event_is_tier1, event_any), text_size=size.small)

    table.cell(dash, 0, 13, "Scores", text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.small)
    table.cell(dash, 1, 13, "A14 " + str.tostring(score_a14) + " | Fly " + str.tostring(score_fly), text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)

    table.cell(dash, 0, 14, "", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 14, "TE " + str.tostring(score_te) + " | TZ " + str.tostring(score_tz) + " | Dir " + str.tostring(score_dir), text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)

    table.cell(dash, 0, 15, "WINNER", text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.small)
    table.cell(dash, 1, 15, action_header, text_color=color.white, bgcolor=color.new(color.blue, 10), text_size=size.normal)

    table.cell(dash, 0, 16, "Conviction", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 16, str.tostring(conviction) + " / 100", text_color=color.white, bgcolor=f_conviction_color(conviction), text_size=size.small)

    table.cell(dash, 0, 17, "Runner-up", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(dash, 1, 17, runner_up + " (" + str.tostring(second_score) + ")", text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

    table.cell(dash, 0, 18, "PLAN", text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.small)
    table.cell(dash, 1, 18, tweaked_plan, text_color=color.white, bgcolor=color.new(color.navy, 20), text_size=size.small)

    table.cell(dash, 0, 19, "ACTION", text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.small)
    table.cell(dash, 1, 19, floor_trade_mode ? "Tiny size - validate on TWS" : "Validate on TWS, enter 3:45-3:55", text_color=color.white, bgcolor=color.new(color.teal, 10), text_size=size.small)

    table.cell(dash, 0, 20, "Open positions", text_color=color.white, bgcolor=color.new(color.black, 40), text_size=size.small)
    table.cell(dash, 1, 20, pos_display + (position_count > 0 ? "(" + str.tostring(position_count) + ")" : ""), text_color=color.white, bgcolor=any_position_open ? color.new(color.orange, 40) : color.new(color.gray, 50), text_size=size.small)

    table.cell(dash, 0, 21, "Data health", text_color=color.white, bgcolor=color.new(color.black, 40), text_size=size.small)
    table.cell(dash, 1, 21, stale_display, text_color=color.white, bgcolor=any_data_stale ? color.new(color.red, 20) : color.new(color.green, 60), text_size=size.small)

// =====================================================================
// 13. ALERTS
// =====================================================================

alertcondition(winner != winner[1] and barstate.isconfirmed, title="STFS v2.5: Winner changed", message="STFS v2.5: Strategy winner has changed.")
alertcondition(floor_trade_mode and not floor_trade_mode[1], title="STFS v2.5: Entered floor trade mode", message="STFS v2.5: Conviction < 50 - floor trade mode.")
alertcondition(not floor_trade_mode and floor_trade_mode[1], title="STFS v2.5: Exited floor trade mode", message="STFS v2.5: Conviction >= 50 - normal strategy selection.")
alertcondition(ctx_state == "CRISIS" and ctx_state[1] != "CRISIS", title="STFS v2.5: CRISIS state", message="STFS v2.5: Context state flipped to CRISIS. Defense only.")
alertcondition(any_data_stale and not any_data_stale[1], title="STFS v2.5: Data stale", message="STFS v2.5: One or more data feeds stale >= 2 bars. Check dashboard Data health row.")
